# ── Groq API Keys (round-robin rotation) ────────────────────────────────
# Get from: https://console.groq.com
KEY1=gsk_your_first_groq_key_here
KEY2=gsk_your_second_groq_key_here
KEY3=gsk_your_third_groq_key_here
KEY4=gsk_your_fourth_groq_key_here

# ── Optional: GNews API (free tier: 100 req/day) ─────────────────────────
# Without this, news signals use synthetic fallback
GNEWS_API_KEY=

# ── Database (auto-configured by docker-compose) ─────────────────────────
# DATABASE_URL=postgresql://postgres:contractguard@db:5432/contractguard

# ── API Security (optional) ───────────────────────────────────────────────
# REQUIRE_API_KEY=true
# API_KEY_HEADER=your_secret_key_here
