DATABASE_URL=postgresql://xxxxxxxxxxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxx@localhost:5432/xxxxxxxxxxxxxxxxxxxx
# Your URL looks correct. The %40 encoding for @ in password is right.

# ── GROQ API KEYS (LLM backbone — rotate on rate-limit) ──
# Load: utils/groq_client.py picks up every KEY* that starts with gsk_
KEY1=gsk_xxxxxxxxxxxxxxxxxxxx
KEY2=gsk_xxxxxxxxxxxxxxxxxxxx
KEY3=gsk_xxxxxxxxxxxxxxxxxxxx
KEY4=gsk_xxxxxxxxxxxxxxxxxxxx

# ── OPTIONAL: Weather API (FM claim validation) ───────────
# Used in: tools/weather_tool.py → WeatherTool.get_rainfall_data()
# If missing → synthetic fallback data is used automatically. Safe to leave blank.
OPENWEATHERMAP_API_KEY=your_owm_key_here

# ── OPTIONAL: News API (contractor risk signals) ──────────
# Used in: tools/news_tool.py → NewsTool.get_entity_news()
# If missing → synthetic news data is used automatically. Safe to leave blank.
NEWSAPI_KEY=your_newsapi_key_here
